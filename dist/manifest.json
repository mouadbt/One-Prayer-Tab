{
  "name": "One Prayer Tab",
  "version": "2.3",
  "manifest_version": 3,
  "description": "A custom new tab page with prayer times, weather and more...",
  "browser_specific_settings": {
    "gecko": {
      "id": "one-prayer-tab@extension.local",
      "strict_min_version": "109.0"
    }
  },
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "background.js"
    ],
    "type": "module"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "history",
    "topSites",
    "alarms",
    "notifications",
    "offscreen"
  ],
  "icons": {
    "128": "assets/images/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/audio/*.m4a",
        "assets/audio/*.mp3"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}